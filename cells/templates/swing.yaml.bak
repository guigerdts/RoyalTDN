- name: swing_reversion
  symbol: LINKUSDT
  timeframe: 1d
  entry:
    logic: AND
    conditions:
    - indicator: zscore
      params:
        period: 20
      operator: < 39.0
  exit:
  - type: zscore
    params:
      threshold: 1.5000000000000002
  risk:
    sizing: 0.06
    max_positions: 1
- name: swing_trend_following
  symbol: BTCUSDT
  timeframe: 1d
  entry:
    logic: AND
    conditions:
    - indicator: ichimoku
      params:
        tenkan: 15
        kijun: 29
        senkou_b: 39
  exit:
  - type: trailing_stop
    params:
      atr_multiplier: 0.5
  risk:
    sizing: 0.025
    max_positions: 2
- name: swing_breakout
  symbol: ETHUSDT
  timeframe: 1d
  entry:
    logic: AND
    conditions:
    - indicator: range_breakout
      params:
        period: 3
        factor: 1.0
    - indicator: volume_surge
      params:
        period: 27
        factor: 2.1
  exit:
  - type: stop_loss
    params:
      atr_multiplier: 1.0
  - type: take_profit
    params:
      atr_multiplier: 4.6000000000000005
  risk:
    sizing: 0.015
    max_positions: 1
- name: swing_mean_reversion
  symbol: SOLUSDT
  timeframe: 1d
  entry:
    logic: AND
    conditions:
    - indicator: zscore
      params:
        period: 20
      operator: < 39.0
  exit:
  - type: zscore
    params:
      threshold: 1.5000000000000002
  risk:
    sizing: 0.06
    max_positions: 1
- name: swing_momentum
  symbol: ADAUSDT
  timeframe: 1d
  entry:
    logic: AND
    conditions:
    - indicator: momentum
      params:
        period: 20
      operator: '> 39.0'
    - indicator: atr
      params:
        period: 37
        max_pct: 6.0
  exit:
  - type: trailing_stop
    params:
      atr_multiplier: 1.3
  risk:
    sizing: 0.02
    max_positions: 1
