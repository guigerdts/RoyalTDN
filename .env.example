# RoyalTDN — Variables de Entorno
# Copia este archivo como .env y completa tus claves.
# NUNCA subas .env al repositorio (está en .gitignore).

# ── Alpaca Markets — Paper Trading (Fase 1) ──────────────────────────────
ALPACA_API_KEY=tu_api_key_aqui
ALPACA_SECRET_KEY=tu_secret_key_aqui

# ── Telegram — Alertas (Fase 2) ──────────────────────────────────────────
# Crear bot con @BotFather en Telegram, copiar token.
# Obtener chat ID: enviar mensaje al bot, luego visitar:
#   https://api.telegram.org/bot<TU_TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── TimescaleDB — Base de datos (Fase 3) ────────────────────────────────
# Usuario, contraseña y nombre de base de datos (docker-compose.yml usa defaults)
POSTGRES_USER=botuser
POSTGRES_PASSWORD=botpassword
POSTGRES_DB=trading_bot
DATABASE_URL=postgresql://botuser:botpassword@db:5432/trading_bot

# ── Redis — Cache y mensajería (Fase 3) ─────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Grafana — Dashboards (Fase 3) ───────────────────────────────────────
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=royaltdn123

# ── Polygon.io — Datos tick/order book (Fase 4+) ────────────────────────
# POLYGON_API_KEY=tu_polygon_key_aqui

# ── Binance Testnet — Crypto Trading (Fase 17) ─────────────────────────
BINANCE_API_KEY="tu_api_key_de_binance_testnet"
BINANCE_SECRET_KEY="tu_secret_key_de_binance_testnet"
BINANCE_TESTNET=true
BROKER_CRYPTO=binance
